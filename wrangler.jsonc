{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "asten-audio-powerpoint",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-11",
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
